# ——— Servidor
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ——— Banco de Dados PostgreSQL (Docker Compose na porta 5433)
DATABASE_URL=postgresql://atseller:atseller123@localhost:5433/atseller

# ——— Autenticação JWT
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_um_secret_seguro_aqui
JWT_REFRESH_SECRET=troque_por_outro_secret_seguro_aqui

# ——— UazAPI (integração WhatsApp)
# URL base da instância UazAPI (self-hosted ou cloud)
UAZAPI_BASE_URL=https://sua-instancia.uazapi.com
# Chave de API gerada no painel UazAPI
UAZAPI_API_KEY=sua_chave_api_aqui

# URL pública do backend para receber webhooks da UazAPI
# Em desenvolvimento: use ngrok ou cloudflare tunnel
# Ex: ngrok http 3001  →  https://abc123.ngrok-free.app
WEBHOOK_BASE_URL=https://seu-dominio-ou-ngrok.com

# ——— OpenAI (agentes GPT-4o + embeddings text-embedding-3-small)
OPENAI_API_KEY=sk-proj-...

# ——— E-mail (recuperação de senha)
# Em desenvolvimento pode deixar vazio — o link de reset aparece no console
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@atseller.io
